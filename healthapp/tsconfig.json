{
  "compilerOptions": {
    "target":"esnext",
    "noImplicitAny": true,
    "noEmit": false,
    "types":["node"],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "module": "nodenext",
    "esModuleInterop": true,
    //"allowImportingTsExtensions": true
  }
}